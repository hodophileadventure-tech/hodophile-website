{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "startCommand": "npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  },
  "nixpacks": {
    "buildScript": "npm run build",
    "environment": {
      "NODE_VERSION": "20",
      "NODE_ENV": "production"
    }
  }
}
